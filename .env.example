# ============================================
# Ultra Video Downloader — Environment Variables
# ============================================

# Download Settings
DOWNLOAD_FOLDER=./downloads
MAX_CONCURRENT_DOWNLOADS=3

# Server
PORT=3000
NODE_ENV=development

# Optional: Custom yt-dlp binary path
# YT_DLP_PATH=yt-dlp

# Optional: Custom FFmpeg binary path
# FFMPEG_PATH=ffmpeg

# Optional: YouTube Anti-Bot Bypass Settings (Required for Cloud/VPS deployments)
# YOUTUBE_COOKIES=# Netscape cookies.txt content or base64 string
# COOKIES_PATH=./data/cookies.txt
# PO_TOKEN=your_youtube_po_token
# YT_DLP_PROXY=http://user:pass@proxy-server:8080

